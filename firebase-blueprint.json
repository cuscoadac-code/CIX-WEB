{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a chat conversation",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "text", "timestamp"]
    },
    "GeneratedImage": {
      "title": "GeneratedImage",
      "description": "An image generated by the AI",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "prompt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "prompt", "imageUrl", "timestamp"]
    },
    "TalentApplication": {
      "title": "TalentApplication",
      "description": "A talent application form submission",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "nickname": { "type": "string" },
        "email": { "type": "string" },
        "superpower": { "type": "string" },
        "glitch": { "type": "string" },
        "rabbitHole": { "type": "string" },
        "challenge48h": { "type": "string" },
        "unlearning": { "type": "string" },
        "divergentChallenge": { "type": "string" },
        "divergentSolution": { "type": "string" },
        "invisibleTeam": { "type": "string" },
        "vision2030": { "type": "string" },
        "infoProcessing": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nickname", "email", "superpower", "glitch", "rabbitHole", "challenge48h", "unlearning", "divergentChallenge", "divergentSolution", "invisibleTeam", "vision2030", "infoProcessing", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "User chat messages"
    },
    "/users/{userId}/images/{imageId}": {
      "schema": "GeneratedImage",
      "description": "User generated images"
    },
    "/talent_applications/{applicationId}": {
      "schema": "TalentApplication",
      "description": "Talent application submissions"
    }
  }
}
